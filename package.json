{
  "name": "@coderesolutions/geo-data-loader",
  "version": "1.0.0",
  "type": "module",
  "description": "High-performance geospatial data loader with progressive loading, virtualization, and caching strategies",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run clean",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "geospatial",
    "gis",
    "maps",
    "leaflet",
    "data-loader",
    "progressive-loading",
    "webworker",
    "virtualization",
    "large-datasets"
  ],
  "author": "CodeResolutions & Jhafet Cánepa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coderesolutions/geo-data-loader"
  },
  "peerDependencies": {
    "leaflet": ">=1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/leaflet": "^1.9.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "leaflet": "^1.9.4",
    "rimraf": "^5.0.0",
    "rollup": "^3.28.0",
    "rollup-plugin-dts": "^6.0.0",
    "rollup-plugin-filesize": "^10.0.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "sideEffects": false,
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
